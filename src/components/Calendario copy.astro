---
// Calendario.astro - Quinceañera Edition ✨
---

<section class="py-8 px-6 sm:px-8 md:px-12 lg:px-16">
  <div class="max-w-3xl mx-auto relative">
    <!-- CONTENEDOR DEL CALENDARIO -->
    <div class="max-w-xl mx-auto px-4 relative">
      <!-- FLORES LATERALES IZQUIERDA -->
      <!-- <div
        class="absolute -left-8 md:-left-16 lg:-left-20 top-24 md:top-28 w-24 md:w-32 lg:w-40 pointer-events-none z-0"
        id="flores-cal-izq"
      >
        <img
          src="/imagenes/FlorLateral.webp"
          alt="Flores"
          class="w-full h-auto object-contain scale-x-[-1]"
        />
      </div> -->

      <!-- FLORES LATERALES DERECHA -->
      <!-- <div
        class="absolute -right-8 md:-right-16 lg:-right-20 top-24 md:top-28 w-24 md:w-32 lg:w-40 pointer-events-none z-0"
        id="flores-cal-der"
      >
        <img
          src="/imagenes/FlorLateral.webp"
          alt="Flores"
          class="w-full h-auto object-contain"
        />
      </div> -->

      <!-- CARD GLASSMORPHISM -->
      <div
        class="cal-card rounded-3xl p-4 md:p-8 relative z-10"
        id="calendario-card"
      >
        <!-- Destellos decorativos internos -->
        <div class="sparkle sparkle-1"></div>
        <div class="sparkle sparkle-2"></div>
        <div class="sparkle sparkle-3"></div>

        <!-- MARIPOSAS + TÍTULO DEL MES -->
        <div
          class="flex items-center justify-center gap-4 md:gap-6 mb-6"
          id="titulo-mes-container"
        >
          <!-- Mariposa izquierda -->
          <div id="mariposa-cal-izq">
            <img
              src="/gif/esferagif.gif"
              alt="Mariposa"
              class="w-10 h-10 md:w-14 md:h-14 object-contain"
            />
          </div>

          <!-- Título -->
          <h3
            class="font-charm text-2xl md:text-4xl font-bold nombre-mes-texto"
            id="nombre-mes"
          >
            <!-- Se llenará con JavaScript -->
          </h3>

          <!-- Mariposa derecha -->
          <div id="mariposa-cal-der">
            <img
              src="/gif/esferagif.gif"
              alt="Mariposa"
              class="w-10 h-10 md:w-14 md:h-14 object-contain scale-x-[-1]"
            />
          </div>
        </div>

        <!-- SEPARADOR DECORATIVO -->
        <div class="separador-cal mb-4"></div>

        <!-- DÍAS DE LA SEMANA -->
        <div class="grid grid-cols-7 gap-1 md:gap-2 mb-3">
          {
            ["D", "L", "M", "M", "J", "V", "S"].map((d) => (
              <div class="text-center font-charm text-sm md:text-base dia-semana font-bold">
                {d}
              </div>
            ))
          }
        </div>

        <!-- DÍAS DEL MES -->
        <div class="grid grid-cols-7 gap-1 md:gap-2" id="dias-container">
          <!-- Se llenará con JavaScript -->
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  import { gsap } from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";

  gsap.registerPlugin(ScrollTrigger);

  // ═══════════════════════════════════════════════════════════
  // ⭐ CONFIGURACIÓN DE LA FECHA ⭐
  // ═══════════════════════════════════════════════════════════
  const DIA_ESPECIAL = 28;
  const MES_ESPECIAL = 3;
  const AÑO_ESPECIAL = 2026;
  // ═══════════════════════════════════════════════════════════

  const NOMBRES_MESES = [
    "Enero",
    "Febrero",
    "Marzo",
    "Abril",
    "Mayo",
    "Junio",
    "Julio",
    "Agosto",
    "Septiembre",
    "Octubre",
    "Noviembre",
    "Diciembre",
  ];

  function generarCalendario() {
    document.getElementById("nombre-mes").textContent =
      `${NOMBRES_MESES[MES_ESPECIAL - 1]} ${AÑO_ESPECIAL}`;

    const primerDia = new Date(AÑO_ESPECIAL, MES_ESPECIAL - 1, 1).getDay();
    const ultimoDia = new Date(AÑO_ESPECIAL, MES_ESPECIAL, 0).getDate();
    const diasContainer = document.getElementById("dias-container");
    diasContainer.innerHTML = "";

    for (let i = 0; i < primerDia; i++) {
      diasContainer.appendChild(document.createElement("div"));
    }

    for (let dia = 1; dia <= ultimoDia; dia++) {
      const diaDiv = document.createElement("div");

      if (dia === DIA_ESPECIAL) {
        diaDiv.className =
          "aspect-square flex items-center justify-center rounded-xl dia-especial-cell dia-calendario";
        diaDiv.id = "dia-especial";
        diaDiv.innerHTML = `
          <span class="font-charm text-2xl md:text-3xl font-bold dia-especial-num" style="color:#00e8ff !important; text-shadow:0 0 14px rgba(0,232,255,1), 0 0 30px rgba(0,232,255,0.7), 0 2px 4px rgba(0,0,0,0.3);">${dia}</span>
        `;
      } else {
        diaDiv.className =
          "aspect-square flex items-center justify-center rounded-lg dia-normal-cell transition-all dia-calendario";
        diaDiv.innerHTML = `<span class="font-charm text-base md:text-lg" style="color:#ffffff !important; text-shadow:0 1px 6px rgba(0,0,0,0.9), 0 0 12px rgba(0,0,0,0.7); font-weight:700;">${dia}</span>`;
      }

      diasContainer.appendChild(diaDiv);
    }
  }

  if (typeof window !== "undefined") {
    document.addEventListener("DOMContentLoaded", () => {
      generarCalendario();

      // Estado inicial
      gsap.set("#flores-cal-izq", { opacity: 0, x: 60 });
      gsap.set("#flores-cal-der", { opacity: 0, x: -60 });
      gsap.set("#calendario-card", { opacity: 0, scale: 0.95, y: 20 });
      gsap.set("#mariposa-cal-izq", { opacity: 0, x: -20 });
      gsap.set("#mariposa-cal-der", { opacity: 0, x: 20 });
      gsap.set("#titulo-mes-container h3", { opacity: 0, y: -10 });
      gsap.set(".dia-calendario", { opacity: 0, scale: 0.8 });

      ScrollTrigger.create({
        trigger: "#calendario-card",
        start: "top 85%",
        onEnter: () => animarCalendario(),
        onLeaveBack: () => ocultarCalendario(),
      });

      function animarCalendario() {
        const tl = gsap.timeline();

        tl.to("#calendario-card", {
          opacity: 1,
          scale: 1,
          y: 0,
          duration: 0.7,
          ease: "power3.out",
        })
          .to(
            "#titulo-mes-container h3",
            {
              opacity: 1,
              y: 0,
              duration: 0.5,
              ease: "power2.out",
            },
            "-=0.3",
          )
          .to(
            "#mariposa-cal-izq, #mariposa-cal-der",
            {
              opacity: 1,
              x: 0,
              duration: 0.5,
              ease: "back.out(1.5)",
            },
            "-=0.3",
          )
          .to(
            ".dia-calendario",
            {
              opacity: 1,
              scale: 1,
              duration: 0.4,
              ease: "power2.out",
              stagger: { amount: 0.5, from: "start" },
            },
            "-=0.2",
          )
          .to(
            "#flores-cal-izq, #flores-cal-der",
            {
              opacity: 1,
              x: 0,
              duration: 0.8,
              ease: "power2.out",
            },
            "-=0.3",
          );
      }

      function ocultarCalendario() {
        gsap.set("#flores-cal-izq", { opacity: 0, x: 60 });
        gsap.set("#flores-cal-der", { opacity: 0, x: -60 });
        gsap.set("#calendario-card", { opacity: 0, scale: 0.95, y: 20 });
        gsap.set("#mariposa-cal-izq", { opacity: 0, x: -20 });
        gsap.set("#mariposa-cal-der", { opacity: 0, x: 20 });
        gsap.set("#titulo-mes-container h3", { opacity: 0, y: -10 });
        gsap.set(".dia-calendario", { opacity: 0, scale: 0.8 });
      }

      // 🦋 Flotado mariposas
      gsap.to("#mariposa-cal-izq", {
        y: -8,
        duration: 3,
        ease: "sine.inOut",
        yoyo: true,
        repeat: -1,
        delay: 1,
      });
      gsap.to("#mariposa-cal-der", {
        y: -8,
        duration: 3,
        ease: "sine.inOut",
        yoyo: true,
        repeat: -1,
        delay: 1.2,
      });

      // ⭐ Pulso día especial
      gsap.to("#dia-especial", {
        scale: 1.06,
        duration: 2.5,
        ease: "sine.inOut",
        yoyo: true,
        repeat: -1,
        delay: 2,
      });

      // ✨ Destellos flotantes
      gsap.to(".sparkle-1", {
        y: -6,
        opacity: 0.6,
        duration: 2.8,
        ease: "sine.inOut",
        yoyo: true,
        repeat: -1,
      });
      gsap.to(".sparkle-2", {
        y: -4,
        opacity: 0.4,
        duration: 3.4,
        ease: "sine.inOut",
        yoyo: true,
        repeat: -1,
        delay: 0.8,
      });
      gsap.to(".sparkle-3", {
        y: -8,
        opacity: 0.5,
        duration: 2.2,
        ease: "sine.inOut",
        yoyo: true,
        repeat: -1,
        delay: 1.5,
      });
    });
  }
</script>

<style>
  /* ═══════════════════════════════════════
     PALETA: #00e8ff + #ffffff
  ═══════════════════════════════════════ */
  :root {
    --cyan: #00e8ff;
    --cyan-light: #7df4ff;
    --cyan-dark: #00b8cc;
    --white: #ffffff;
    --white-90: rgba(255, 255, 255, 0.9);
    --white-60: rgba(255, 255, 255, 0.6);
    --white-30: rgba(255, 255, 255, 0.3);
    --white-10: rgba(255, 255, 255, 0.1);
    --cyan-glow: rgba(0, 232, 255, 0.35);
    --cyan-soft: rgba(0, 232, 255, 0.15);
  }

  /* ─── CARD GLASSMORPHISM ELEGANTE ─── */
  .cal-card {
    background: rgba(255, 255, 255, 0.12);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    border: 1.5px solid rgba(255, 255, 255, 0.35);
    box-shadow:
      0 8px 40px rgba(0, 232, 255, 0.18),
      0 2px 8px rgba(255, 255, 255, 0.12),
      inset 0 1px 0 rgba(255, 255, 255, 0.4);
    overflow: hidden;
    position: relative;
  }

  /* Brillo sutil en la esquina superior */
  .cal-card::before {
    content: "";
    position: absolute;
    top: -1px;
    left: 10%;
    width: 80%;
    height: 2px;
    background: linear-gradient(
      90deg,
      transparent,
      rgba(0, 232, 255, 0.7),
      var(--white),
      rgba(0, 232, 255, 0.7),
      transparent
    );
    border-radius: 50%;
  }

  /* Resplandor de fondo del card */
  .cal-card::after {
    content: "";
    position: absolute;
    inset: 0;
    background: radial-gradient(
      ellipse at 50% 0%,
      rgba(0, 232, 255, 0.08) 0%,
      transparent 70%
    );
    pointer-events: none;
  }

  /* ─── TÍTULO DEL MES ─── */
  .nombre-mes-texto {
    color: var(--white);
    text-shadow:
      0 0 20px rgba(0, 232, 255, 0.8),
      0 0 40px rgba(0, 232, 255, 0.4),
      0 2px 4px rgba(0, 0, 0, 0.2);
    letter-spacing: 0.04em;
  }

  /* ─── SEPARADOR ─── */
  .separador-cal {
    height: 1px;
    background: linear-gradient(
      90deg,
      transparent,
      rgba(0, 232, 255, 0.5),
      rgba(255, 255, 255, 0.6),
      rgba(0, 232, 255, 0.5),
      transparent
    );
    margin: 0 1rem;
  }

  /* ─── DÍAS DE LA SEMANA ─── */
  .dia-semana {
    color: var(--cyan-light);
    text-shadow: 0 0 10px rgba(0, 232, 255, 0.5);
    letter-spacing: 0.05em;
  }

  /* ─── NÚMEROS NORMALES ─── */
  .dia-num-normal {
    color: #ffffff !important;
    text-shadow:
      0 0 8px rgba(0, 0, 0, 0.9),
      0 1px 4px rgba(0, 0, 0, 0.8),
      0 2px 8px rgba(0, 0, 0, 0.6);
    font-weight: 700;
  }

  /* ─── CELDA NORMAL HOVER ─── */
  .dia-normal-cell {
    background: rgba(0, 0, 0, 0.15);
  }

  .dia-normal-cell:hover {
    background: rgba(0, 232, 255, 0.18);
    box-shadow: 0 0 10px rgba(0, 232, 255, 0.2);
  }

  /* ─── DÍA ESPECIAL (28) ─── */
  .dia-especial-cell {
    background: linear-gradient(
      135deg,
      rgba(0, 232, 255, 0.55) 0%,
      rgba(255, 255, 255, 0.35) 50%,
      rgba(0, 184, 204, 0.55) 100%
    );
    border: 1.5px solid rgba(255, 255, 255, 0.7);
    box-shadow:
      0 0 20px rgba(0, 232, 255, 0.5),
      0 0 40px rgba(0, 232, 255, 0.25),
      inset 0 1px 0 rgba(255, 255, 255, 0.5);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
  }

  .dia-especial-num {
    color: #00e8ff !important;
    text-shadow:
      0 0 14px rgba(0, 232, 255, 1),
      0 0 28px rgba(0, 232, 255, 0.7),
      0 0 50px rgba(0, 232, 255, 0.4),
      0 2px 4px rgba(0, 0, 0, 0.3);
  }

  /* ─── DESTELLOS DECORATIVOS ─── */
  .sparkle {
    position: absolute;
    border-radius: 50%;
    pointer-events: none;
    opacity: 0.3;
  }

  .sparkle-1 {
    width: 6px;
    height: 6px;
    background: var(--cyan);
    top: 12%;
    right: 8%;
    box-shadow: 0 0 8px 3px rgba(0, 232, 255, 0.6);
  }

  .sparkle-2 {
    width: 4px;
    height: 4px;
    background: var(--white);
    top: 20%;
    left: 10%;
    box-shadow: 0 0 6px 2px rgba(255, 255, 255, 0.5);
  }

  .sparkle-3 {
    width: 5px;
    height: 5px;
    background: var(--cyan-light);
    bottom: 15%;
    right: 12%;
    box-shadow: 0 0 8px 3px rgba(125, 244, 255, 0.5);
  }
</style>
