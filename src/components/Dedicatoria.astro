<section class="py-8 px-4 relative">
  <div class="max-w-3xl mx-auto">
    <!-- ── Separador superior: notas + esferas disco ── -->

    <!-- ── Texto dedicatoria ── -->
    <div class="text-center px-4">
      <h2
        class="font-charm text-2xl sm:text-xl md:text-2xl texto-dedicatoria leading-relaxed"
        id="texto-ded"
      >
        Los sueños se cumplen y hoy uno de los míos se hace realidad. Con la
        bendición de Dios y el amor de mi familia, te invito a celebrar mis 15
        años.
      </h2>
    </div>
  </div>
</section>

<script>
  import { gsap } from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";

  gsap.registerPlugin(ScrollTrigger);

  document.addEventListener("DOMContentLoaded", () => {
    gsap.set("#flores-arriba-ded", { opacity: 0, y: -30 });
    gsap.set("#texto-ded", { opacity: 0, y: 30 });
    gsap.set("#flores-abajo-ded", { opacity: 0, y: 30 });

    ScrollTrigger.create({
      trigger: "#texto-ded",
      start: "top 100%",
      end: "top 20%",
      onEnter: () => animarEntrada(),
      onLeaveBack: () => animarSalida(),
    });

    function animarEntrada() {
      const tl = gsap.timeline();
      tl.to("#flores-arriba-ded", {
        opacity: 1,
        y: 0,
        duration: 0.8,
        ease: "power2.out",
      })
        .to(
          "#texto-ded",
          { opacity: 1, y: 0, duration: 1, ease: "power2.out" },
          "<",
        )
        .to(
          "#flores-abajo-ded",
          { opacity: 1, y: 0, duration: 0.8, ease: "power2.out" },
          "<",
        );
    }

    function animarSalida() {
      const tl = gsap.timeline();
      tl.to("#flores-abajo-ded", {
        opacity: 0,
        y: 30,
        duration: 0.4,
        ease: "power2.in",
      })
        .to(
          "#texto-ded",
          { opacity: 0, y: 30, duration: 0.4, ease: "power2.in" },
          "-=0.3",
        )
        .to(
          "#flores-arriba-ded",
          { opacity: 0, y: -30, duration: 0.4, ease: "power2.in" },
          "-=0.3",
        );
    }
  });
</script>

<style>
  /* Texto dedicatoria: cian con brillo suave */
  .texto-dedicatoria {
    color: #00e8ff;
    text-shadow:
      0 0 8px rgba(0, 232, 255, 0.55),
      0 0 20px rgba(0, 200, 240, 0.25);
  }
</style>
