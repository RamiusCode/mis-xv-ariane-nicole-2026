---
// PaseInvitado.astro - Quinceañera Edition ✨
---

<section class="py-8 px-2 sm:px-8 md:px-12 lg:px-16">
    <div class="max-w-3xl mx-auto relative">
        <div class="max-w-xl mx-auto px-4 relative">
            <div
                class="cal-card rounded-3xl p-6 md:p-10 relative z-10 text-center"
                id="pase-card"
            >
                <!-- Icono ticket -->
                <div class="flex justify-center mb-3">
                    <svg
                        class="w-10 h-10 icono-pase"
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="currentColor"
                    >
                        <path
                            stroke-linecap="round"
                            stroke-linejoin="round"
                            stroke-width="1.5"
                            d="M15 5v2m0 4v2m0 4v2M5 5a2 2 0 00-2 2v3a2 2 0 110 4v3a2 2 0 002 2h14a2 2 0 002-2v-3a2 2 0 110-4V7a2 2 0 00-2-2H5z"
                        ></path>
                    </svg>
                </div>

                <!-- Etiqueta -->
                <p
                    class="font-charm text-xl tracking-[0.25em] uppercase mb-6 etiqueta-pase"
                >
                    Pase de Invitado
                </p>

                <!-- Separador -->
                <div class="separador-cal mb-10"></div>

                <!-- Texto principal -->
                <p class="font-charm text-2xl py-6 font-bold validez-texto">
                    Válido para 1 persona
                </p>

                <!-- Separador -->
                <div class="separador-cal mt-5"></div>
            </div>
        </div>
    </div>
</section>

<script>
    import { gsap } from "gsap";
    import { ScrollTrigger } from "gsap/ScrollTrigger";
    gsap.registerPlugin(ScrollTrigger);

    if (typeof window !== "undefined") {
        document.addEventListener("DOMContentLoaded", () => {
            gsap.set("#pase-card", { opacity: 0, scale: 0.95, y: 20 });

            ScrollTrigger.create({
                trigger: "#pase-card",
                start: "top 85%",
                onEnter: () => {
                    gsap.to("#pase-card", {
                        opacity: 1,
                        scale: 1,
                        y: 0,
                        duration: 0.7,
                        ease: "power3.out",
                    });
                },
                onLeaveBack: () => {
                    gsap.set("#pase-card", { opacity: 0, scale: 0.95, y: 20 });
                },
            });
        });
    }
</script>

<style>
    :root {
        --cyan: #00e8ff;
        --cyan-light: #7df4ff;
        --white: #ffffff;
    }

    /* ─── CARD GLASSMORPHISM — idéntico al Calendario ─── */
    .cal-card {
        background: rgba(255, 255, 255, 0.12);
        backdrop-filter: blur(20px);
        -webkit-backdrop-filter: blur(20px);
        border: 1.5px solid rgba(255, 255, 255, 0.35);
        box-shadow:
            0 8px 40px rgba(0, 232, 255, 0.18),
            0 2px 8px rgba(255, 255, 255, 0.12),
            inset 0 1px 0 rgba(255, 255, 255, 0.4);
        overflow: hidden;
        position: relative;
    }

    .cal-card::before {
        content: "";
        position: absolute;
        top: -1px;
        left: 10%;
        width: 80%;
        height: 2px;
        background: linear-gradient(
            90deg,
            transparent,
            rgba(0, 232, 255, 0.7),
            var(--white),
            rgba(0, 232, 255, 0.7),
            transparent
        );
        border-radius: 50%;
    }

    .cal-card::after {
        content: "";
        position: absolute;
        inset: 0;
        background: radial-gradient(
            ellipse at 50% 0%,
            rgba(0, 232, 255, 0.08) 0%,
            transparent 70%
        );
        pointer-events: none;
    }

    /* ─── SEPARADOR ─── */
    .separador-cal {
        height: 1px;
        background: linear-gradient(
            90deg,
            transparent,
            rgba(0, 232, 255, 0.5),
            rgba(255, 255, 255, 0.6),
            rgba(0, 232, 255, 0.5),
            transparent
        );
        margin: 0 1rem;
    }

    /* ─── TEXTOS ─── */
    .etiqueta-pase {
        color: rgba(0, 232, 255, 0.75);
        text-shadow: 0 0 8px rgba(0, 232, 255, 0.4);
    }

    .validez-texto {
        color: #ffffff;
        text-shadow:
            0 0 20px rgba(0, 232, 255, 0.8),
            0 0 40px rgba(0, 232, 255, 0.4),
            0 2px 4px rgba(0, 0, 0, 0.2);
    }

    /* ─── ICONO ─── */
    .icono-pase {
        color: #00e8ff;
        filter: drop-shadow(0 0 6px rgba(0, 232, 255, 0.7));
    }
</style>
