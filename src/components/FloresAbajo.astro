---
// Final.astro
---

<section class="relative w-full xl:px-40 overflow-hidden" id="seccion-final">
  <!-- ESPACIO RESERVADO (antes tenía las esferas flotantes) -->
  <div class="relative w-full h-32 md:h-40 lg:h-48" id="mariposas-final"></div>

  <!-- CONTENEDOR CON IMAGEN SOBRE FLORES -->
  <div class="relative w-full" id="imagen-flores-container">
    <!-- FLORES ABAJO - FULL WIDTH VOLTEADAS -->
    <div class="relative w-full" id="flores-final">
      <img
        src="/imagenes/esferas.png"
        alt="Flores decorativas finales"
        class="w-full h-auto object-cover object-center block rotate-180"
      />
    </div>

    <!-- IMAGEN QUINCEAÑERA SOBRE LAS FLORES -->
    <div
      class="absolute inset-0 flex items-center justify-center"
      id="imagen-quinceañera-container"
    >
      <div id="imagen-quinceañera">
        <img
          src="/imagenes/silueta.png"
          alt="Quinceañera"
          class="w-56 h-auto object-contain drop-shadow-2xl"
          style="display:block; margin:0 auto;"
        />
      </div>
    </div>
  </div>
</section>

<script>
  import { gsap } from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";

  gsap.registerPlugin(ScrollTrigger);

  if (typeof window !== "undefined") {
    document.addEventListener("DOMContentLoaded", () => {
      gsap.set("#flores-final", { opacity: 0, y: 30 });
      gsap.set("#imagen-quinceañera", { opacity: 0, scale: 0.9, y: 40 });

      ScrollTrigger.create({
        trigger: "#seccion-final",
        start: "top 80%",
        onEnter: () => {
          const tl = gsap.timeline();
          tl.to(
            "#flores-final",
            { opacity: 1, y: 0, duration: 0.8, ease: "power2.out" },
            0,
          ).to(
            "#imagen-quinceañera",
            { opacity: 1, scale: 1, y: 0, duration: 0.8, ease: "power3.out" },
            0,
          );
        },
        onLeaveBack: () => {
          gsap.set("#flores-final", { opacity: 0, y: 30 });
          gsap.set("#imagen-quinceañera", { opacity: 0, scale: 0.9, y: 40 });
        },
      });
    });
  }
</script>

<style>
  #imagen-quinceañera img {
    transition: transform 0.5s ease;
  }

  #imagen-quinceañera:hover img {
    transform: scale(1.03);
  }
</style>
